---
import BaseLayout from '../layouts/BaseLayout.astro';

const platforms = [
  {
    name: "Theaters",
    status: "Coming Soon",
    date: "July 10, 2026",
    description: "Moana live action will have a wide theatrical release including IMAX and premium formats.",
    icon: "🎬",
    available: false
  },
  {
    name: "Disney+",
    status: "Coming Later",
    date: "Late 2026 (Expected)",
    description: "Expected to arrive on Disney+ approximately 45-90 days after the theatrical release.",
    icon: "🏰",
    available: false
  },
  {
    name: "Amazon Prime Video",
    status: "Rental/Purchase",
    date: "Late 2026 (Expected)",
    description: "Digital rental and purchase options will likely be available after the theatrical window.",
    icon: "📺",
    available: false
  },
  {
    name: "Apple TV",
    status: "Rental/Purchase",
    date: "Late 2026 (Expected)",
    description: "Will be available for digital rental and purchase on iTunes/Apple TV.",
    icon: "🍎",
    available: false
  },
  {
    name: "Blu-ray & 4K UHD",
    status: "Physical Media",
    date: "Late 2026 (Expected)",
    description: "Blu-ray, 4K UHD, and Digital HD versions will be released for home collection.",
    icon: "💿",
    available: false
  }
];
---

<BaseLayout
  title="Where to Watch Moana Live Action - Theaters, Disney+ & Streaming (2026)"
  description="Where can you watch Moana live action? Find out about theatrical release, Disney+ streaming date, digital rental, and physical media options for the 2026 Moana live action movie."
  keywords="where to watch moana live action, moana streaming, moana disney plus, moana digital release, moana blu-ray, watch moana 2026 online"
>
  <section class="page-header">
    <div class="container">
      <h1>Where to Watch Moana Live Action</h1>
      <p>Theaters, streaming platforms, and digital purchase options</p>
    </div>
  </section>

  <section class="platforms-section">
    <div class="container">
      <h2>Available Platforms</h2>
      <div class="platforms-grid">
        {platforms.map(platform => (
          <div class="platform-card">
            <span class="platform-icon">{platform.icon}</span>
            <h3>{platform.name}</h3>
            <span class="platform-status">{platform.status}</span>
            <p>{platform.description}</p>
            <span class="platform-date">📅 {platform.date}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="container">
      <h2>Release Window Timeline</h2>
      <div class="release-stages">
        <div class="stage">
          <div class="stage-number">1</div>
          <div class="stage-info">
            <h3>Theatrical Release</h3>
            <p class="stage-date">July 10, 2026</p>
            <p>Catch it on the big screen! The best way to experience Moana live action with stunning visuals and sound.</p>
          </div>
        </div>
        <div class="stage">
          <div class="stage-number">2</div>
          <div class="stage-info">
            <h3>Premium Video on Demand</h3>
            <p class="stage-date">September 2026 (Estimated)</p>
            <p>Rent or purchase digitally through platforms like Apple TV and Amazon Prime Video.</p>
          </div>
        </div>
        <div class="stage">
          <div class="stage-number">3</div>
          <div class="stage-info">
            <h3>Disney+ Streaming</h3>
            <p class="stage-date">October-November 2026 (Estimated)</p>
            <p>Stream exclusively on Disney+ from the comfort of your home.</p>
          </div>
        </div>
        <div class="stage">
          <div class="stage-number">4</div>
          <div class="stage-info">
            <h3>Physical Media</h3>
            <p class="stage-date">Holiday 2026 (Estimated)</p>
            <p>Own it forever on Blu-ray, 4K UHD, and Digital HD with bonus features.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="seo-content">
    <div class="container">
      <h2>How to Watch Moana Live Action</h2>
      <p>Moana live action will be available in theaters starting <strong>July 10, 2026</strong>. Following the theatrical run, the film will be available on <strong>Disney+</strong> for streaming, as well as through digital rental and purchase on platforms like <strong>Apple TV</strong> and <strong>Amazon Prime Video</strong>.</p>
      
      <h3>Will Moana Live Action Be on Disney+?</h3>
      <p>Yes! As a Disney production, Moana live action will be available on Disney+ following its theatrical run. Based on Disney's recent release patterns, expect it to arrive on the platform approximately <strong>2-3 months</strong> after the theatrical premiere.</p>
      
      <h3>When Can I Buy Moana Live Action on Digital?</h3>
      <p>Digital rental and purchase options typically become available <strong>45-60 days</strong> after the theatrical release. You'll be able to find it on Apple TV, Amazon Prime Video, Google Play, and other major digital platforms.</p>
      
      <h3>Will There Be a Blu-ray Release?</h3>
      <p>Yes, Disney typically releases physical media (Blu-ray and 4K UHD) approximately <strong>3-4 months</strong> after the theatrical premiere. Expect bonus features including behind-the-scenes content, deleted scenes, and director's commentary.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #0077be 0%, #00d4aa 100%);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }
  
  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  
  .page-header p {
    opacity: 0.9;
    font-size: 1.1rem;
  }
  
  .platforms-section {
    padding: 4rem 0;
  }
  
  .platforms-section h2 {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--dark);
  }
  
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  
  .platform-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    text-align: center;
    transition: transform 0.2s;
  }
  
  .platform-card:hover {
    transform: translateY(-2px);
  }
  
  .platform-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
  }
  
  .platform-card h3 {
    color: var(--dark);
    margin-bottom: 0.5rem;
  }
  
  .platform-status {
    display: inline-block;
    background: var(--light);
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    color: var(--primary);
    font-weight: 600;
  }
  
  .platform-card p {
    color: var(--text-light);
    margin: 1rem 0;
    font-size: 0.95rem;
  }
  
  .platform-date {
    color: var(--text-light);
    font-size: 0.85rem;
  }
  
  .timeline-section {
    padding: 4rem 0;
    background: var(--light);
  }
  
  .timeline-section h2 {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--dark);
  }
  
  .release-stages {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .stage {
    display: flex;
    align-items: flex-start;
    margin-bottom: 2rem;
  }
  
  .stage-number {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: var(--primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.25rem;
    margin-right: 1.5rem;
  }
  
  .stage-info {
    flex: 1;
  }
  
  .stage-info h3 {
    color: var(--dark);
    margin-bottom: 0.25rem;
  }
  
  .stage-date {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  
  .stage-info p {
    color: var(--text-light);
    font-size: 0.95rem;
  }
  
  .seo-content {
    padding: 4rem 0;
    background: white;
  }
  
  .seo-content .container {
    max-width: 800px;
  }
  
  .seo-content h2 {
    margin-bottom: 1rem;
    color: var(--dark);
  }
  
  .seo-content h3 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--dark);
  }
  
  .seo-content p {
    color: var(--text-light);
    margin-bottom: 1rem;
  }
  
  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }
  }
</style>
